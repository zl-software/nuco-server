# coturn configuration for Nuco voice calls. Copy to coturn/turnserver.conf (gitignored)
# and adjust the values marked CHANGE. The relay issues short lived credentials in the
# TURN REST scheme; coturn verifies them against the shared secret below, so the two MUST
# match (static-auth-secret here, RELAY_TURN_SECRET / TURN_SECRET in .env).

listening-port=3478
fingerprint

# TURN REST API (time limited credentials). Generate the secret with: openssl rand -hex 32
use-auth-secret
static-auth-secret=CHANGE_ME_SHARED_SECRET
realm=turn.example.org

# Relay media ports. 200 UDP ports is roughly 100 concurrent allocations, about 50 calls
# (each 1:1 call allocates once per endpoint). Open this range in your firewall along with
# 3478 udp and tcp.
min-port=49160
max-port=49360

# Behind 1:1 NAT (most cloud VMs): tell coturn its public and private address.
# external-ip=203.0.113.10/10.0.0.5

# Plain turn: only. Media confidentiality does not depend on the TURN transport (the
# payload is end to end encrypted DTLS-SRTP); turns: mainly helps through restrictive
# firewalls. To enable it, point cert and pkey at your certificate, remove no-tls, and
# restart coturn after every certificate renewal (it does not reload certs on its own).
no-tls
no-dtls

# Abuse and SSRF hardening: the TURN server must never relay into local or private
# networks, and peers other than the two call endpoints have no business here.
no-multicast-peers
no-cli
no-rfc5780
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.0.0.0-192.0.0.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=198.18.0.0-198.19.255.255
denied-peer-ip=224.0.0.0-255.255.255.255
denied-peer-ip=::1
denied-peer-ip=fe80::-febf:ffff:ffff:ffff:ffff:ffff:ffff:ffff
denied-peer-ip=fc00::-fdff:ffff:ffff:ffff:ffff:ffff:ffff:ffff

# Capacity. Opus voice with SRTP and TURN overhead stays under 90 kbps, so 64 KB/s per
# allocation is generous headroom. Tune for your host.
total-quota=100
user-quota=8
max-bps=65536
stale-nonce=600
