# Nuco relay configuration. Copy to .env and adjust. Never commit your real .env.

# Set to 1 for local development: no TLS, in memory or temp SQLite, push is mocked
# (the APNs and UnifiedPush calls are logged instead of sent). Unset or 0 for production.
RELAY_DEV=0

# WebSocket and HTTP listen settings.
RELAY_HOST=0.0.0.0
RELAY_PORT=8787

# TLS. Leave empty to terminate TLS at a reverse proxy (recommended: Caddy or nginx).
# To terminate TLS in process, point these at your certificate and private key.
RELAY_TLS_CERT=
RELAY_TLS_KEY=

# Storage backend. sqlite is the default and only built in backend.
RELAY_STORAGE=sqlite
RELAY_SQLITE_PATH=./data/nuco.sqlite

# Queue limits per recipient.
RELAY_QUEUE_MAX=1000
RELAY_QUEUE_TTL_SECONDS=2592000

# Abuse controls (per connection and per ip).
RELAY_RATE_MAX_PER_MIN=600

# Maximum sealed envelope size in bytes (above the largest padding bucket plus overhead).
RELAY_MAX_MESSAGE_BYTES=131072

# Voice calls (optional). Set both RELAY_TURN_* values to enable TURN credential issuance;
# leave them empty and the relay answers CALLS_UNAVAILABLE (messaging is unaffected). The
# secret MUST equal static-auth-secret in coturn/turnserver.conf; generate it with
# openssl rand -hex 32. TURN_SECRET is the compose side alias referenced by
# docker-compose.yml so the same value reaches the relay container. The TTL caps how long
# an established call can refresh its TURN allocation, so it also bounds call length.
RELAY_TURN_SECRET=
RELAY_TURN_URLS=
RELAY_TURN_TTL_SECONDS=7200
TURN_SECRET=

# Apple Push Notification service (optional). If APNS_KEY_PATH is empty the relay runs
# without iOS push. The .p8 file must be kept out of git and mounted as a secret.
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# Use the Apple sandbox host for development builds, production host for the store build.
APNS_HOST=api.push.apple.com
